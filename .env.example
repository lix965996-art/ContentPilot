# Copy this file to .env before running Docker Compose.
CONTENTPILOT_PORT=8080
CONTENTPILOT_API_PORT=8000

# Use long, unique values in a real deployment. Keep MySQL passwords URL-safe.
MYSQL_PASSWORD=changeMeMysql2026
MYSQL_ROOT_PASSWORD=changeMeRoot2026
JWT_SECRET=change-this-to-a-random-secret-with-at-least-32-characters
PLATFORM_CREDENTIAL_KEY=change-this-to-a-different-random-32-character-secret

# Keep production data clean. Set true only when you explicitly need sample content.
APP_DEMO_MODE=false
MEDIA_FALLBACK_ENABLED=true
PUBLISH_MODE=manual

# Optional: these can also be configured later from the administrator UI.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
UNSPLASH_ACCESS_KEY=
